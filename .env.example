APP_NAME=TicketWave
APP_ENV=local
APP_KEY=                          # se genera con: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Base de datos ────────────────────────────────────────────────────────────
# El host es el nombre del servicio en docker-compose.yml, NO "localhost"
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ticketwave
DB_USERNAME=ticketwave_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret_root

# ─── Cache y sesiones ────────────────────────────────────────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Mail (para notificaciones de compra) ────────────────────────────────────
MAIL_MAILER=log                   # en local escribe al log, no envía emails reales
MAIL_FROM_ADDRESS="noreply@ticketwave.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage ─────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
