# ─── Control de versiones ────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Dependencias (se instalan dentro del contenedor) ────────────────────────
vendor/
node_modules/

# ─── Archivos de entorno (nunca al contenedor de producción) ─────────────────
.env
.env.*
!.env.example

# ─── Cache y archivos generados ──────────────────────────────────────────────
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
bootstrap/cache/*

# ─── Documentación y archivos del equipo ─────────────────────────────────────
docs/
*.md
README*

# ─── Docker (evitar recursividad) ────────────────────────────────────────────
docker/
docker-compose*.yml
Dockerfile*

# ─── IDE y herramientas locales ───────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
Thumbs.db
